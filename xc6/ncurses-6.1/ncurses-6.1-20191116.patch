--- ncurses-6.1-20191109+/NEWS	2019-11-10 00:18:59.000000000 +0000
+++ ncurses-6.1-20191116/NEWS	2019-11-16 20:48:27.000000000 +0000
@@ -25,7 +25,7 @@
 -- sale, use or other dealings in this Software without prior written        --
